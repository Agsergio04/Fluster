                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fecha\": \"2025-02-01T08:00:00.000Z\",\n  \"clienteId\": \"{{clienteId}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/contenedores/{{contenedorId}}/entrada-puerto",
              "host": ["{{baseUrl}}"],
              "path": ["api", "contenedores", "{{contenedorId}}", "entrada-puerto"]
            },
            "description": "Registra la entrada fĂ­sica del contenedor al puerto. Transiciona `INACTIVO â†’ PUERTO` y abre un nuevo ciclo D&D con el cliente indicado. Solo `gestor`.\n\n**Campos:**\n- `fecha` â€” fecha real de entrada al puerto\n- `clienteId` â€” cliente al que pertenece este ciclo\n\n**Errores:**\n- `404` â€” contenedor no encontrado\n- `422` â€” el contenedor no estĂˇ en estado `INACTIVO`"
          },
          "response": []
        },
        {
          "name": "Salida del puerto â€” PUERTO â†’ CLIENTE",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
