    {
      "name": "Contenedores",
      "description": "GestiĂłn del ciclo de vida de los contenedores. Lectura: `operador` y `gestor`. Escritura: `operador` (alta), `gestor` (resto).",
      "item": [
        {
          "name": "Listar contenedores",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/contenedores",
              "host": ["{{baseUrl}}"],
              "path": ["api", "contenedores"],
              "query": [
                { "key": "estado",      "value": "PUERTO",       "disabled": true, "description": "INACTIVO | PUERTO | CLIENTE" },
                { "key": "navieraId",   "value": "{{navieraId}}", "disabled": true },
                { "key": "clienteId",   "value": "{{clienteId}}", "disabled": true }
              ]
            },
            "description": "Lista todos los contenedores. Acepta filtros opcionales por query param.\n\n**Filtros (todos opcionales):**\n- `estado` â€” `INACTIVO` | `PUERTO` | `CLIENTE`\n- `navieraId` â€” ID de naviera\n- `clienteId` â€” ID de cliente (busca en ciclos asociados)"
          },
          "response": []
