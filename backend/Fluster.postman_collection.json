              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"codigoBIC\": \"MSCU1234567\",\n  \"tipo\": \"20DC\",\n  \"navieraId\": \"{{navieraId}}\",\n  \"fechaInicioLibre\": \"2025-01-01T00:00:00.000Z\"\n}",
